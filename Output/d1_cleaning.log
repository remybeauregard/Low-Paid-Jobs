. // ── Write regression tables ────────────────────────────────────────────────────
. // Stata local macro names are limited to 32 characters. Variable names such as
. // jobfactors_hoursflexibility (27 chars) would exceed that limit if used as part
. // of a cell key (e.g. cell_jobfactors_hoursflexibility_m1w = 36 chars). Instead,
. // cells are stored using numeric indices: c_i_j where i = var index (1-8) and
. // j = model index (1-4). Maximum name length is 6 chars (e.g. c_8_4).
. 
. // Map numeric index to full variable name (for sig_cell and label lookups)
. local var1 jobfactors_profdev

. local var2 jobfactors_familyopinion

. local var3 jobfactors_peeropinion

. local var4 jobfactors_location

. local var5 jobfactors_hoursflexibility

. local var6 jobfactors_qualifications

. local var7 jobfactors_promotion

. local var8 jobfactors_training

. 
. // The forvalues loop (s=1: original wages; s=2: winsorised wages) generates
. // regtable_table.tex and regtable_w_table.tex respectively.
. 
. forvalues s = 1/2 {
  2. 
.     // Table-specific settings
.     if `s' == 1 {
  3.         local outfile "../Report/regtable_table.tex"
  4.         local caption "Summary of OLS Regression Results"
  5.         local tlabel  "tab:regs"
  6.         local m1_ m1
  7.         local m2_ m2
  8.         local m3_ m3
  9.         local m4_ m4
 10.     }
 11.     else {
 12.         local outfile "../Report/regtable_w_table.tex"
 13.         local caption "OLS Regression Results: Winsorised Wages (5th/95th Percentile)"
 14.         local tlabel  "tab:regsw"
 15.         local m1_ m1w
 16.         local m2_ m2w
 17.         local m3_ m3w
 18.         local m4_ m4w
 19.     }
 20. 
.     // Compute all 32 significance cells using numeric indices i (var) and j (model)
.     // c_i_j stores "+***", "-**", or "ns" — all well within the 32-char name limit.
.     forvalues i = 1/8 {
 21.         local v = "`var`i''"
 22.         forvalues j = 1/4 {
 23.             local mj = "`m`j'_'"
 24.             sig_cell `mj' `v'
 25.             local c_`i'_`j' = r(cell)
 26.         }
 27.     }
 28. 
.     // Retrieve N for each model using the same j index
.     forvalues j = 1/4 {
 29.         local mj = "`m`j'_'"
 30.         quietly estimates restore `mj'
 31.         local N_`j' = e(N)
 32.     }
 33. 
.     // Partition variable indices into significant (any model) and non-significant
.     local sig_idx ""
 34.     local nonsig_idx ""
 35.     forvalues i = 1/8 {
 36.         local any = 0
 37.         forvalues j = 1/4 {
 38.             if "`c_`i'_`j''" != "ns" {
 39.                 local any = 1
 40.             }
 41.         }
 42.         if `any' {
 43.             local sig_idx "`sig_idx' `i'"
 44.         }
 45.         else {
 46.             local nonsig_idx "`nonsig_idx' `i'"
 47.         }
 48.     }
 49. 
.     // Write the complete table file
.     file open tf using "`outfile'", write replace
 50.     file write tf "\begin{table}[h!]" _n
 51.     file write tf "\centering" _n
 52.     file write tf "\caption{`caption'}" _n
 53.     file write tf "\label{`tlabel'}" _n
 54.     file write tf "\begin{tabular}{l*{4}{>{\centering\arraybackslash}p{1.6cm}}}" _n
 55.     file write tf "\toprule" _n
 56.     file write tf " & \multicolumn{2}{c}{\textbf{Min WTA}} & \multicolumn{2}{c}{\textbf
> {Max WTA}} \\" _n
 57.     file write tf "\cmidrule(lr){2-3}\cmidrule(lr){4-5}" _n
 58.     file write tf "\textbf{Job factor} & (1) & (2) & (3) & (4) \\" _n
 59.     file write tf "\midrule" _n
 60.     file write tf "\multicolumn{5}{l}{\textit{Significant predictors}} \\[2pt]" _n
 61. 
.     // Write each row cell-by-cell. _char(36) writes a literal $ to produce
.     // $+$*** / $-$*** formatting (math-mode sign + superscript stars).
. 
.     local n_sig : word count `sig_idx'
 62.     local k = 0
 63.     foreach i of local sig_idx {
 64.         local k = `k' + 1
 65.         local v = "`var`i''"
 66.         local lab "`lab_`v''"
 67.         file write tf "`lab'"
 68.         forvalues j = 1/4 {
 69.             file write tf " & "
 70.             if "`c_`i'_`j''" == "ns" {
 71.                 file write tf "ns"
 72.             }
 73.             else {
 74.                 local sg = substr("`c_`i'_`j''", 1, 1)
 75.                 local st = substr("`c_`i'_`j''", 2, .)
 76.                 file write tf _char(36) "`sg'" _char(36) "`st'"
 77.             }
 78.         }
 79.         if `k' == `n_sig' {
 80.             file write tf " \\[4pt]" _n
 81.         }
 82.         else {
 83.             file write tf " \\" _n
 84.         }
 85.     }
 86. 
.     if "`nonsig_idx'" != "" {
 87.         file write tf "\multicolumn{5}{l}{\textit{Non-significant predictors}} \\[2pt]"
>  _n
 88.         foreach i of local nonsig_idx {
 89.             local v = "`var`i''"
 90.             local lab "`lab_`v''"
 91.             file write tf "`lab'"
 92.             forvalues j = 1/4 {
 93.                 file write tf " & "
 94.                 if "`c_`i'_`j''" == "ns" {
 95.                     file write tf "ns"
 96.                 }
 97.                 else {
 98.                     local sg = substr("`c_`i'_`j''", 1, 1)
 99.                     local st = substr("`c_`i'_`j''", 2, .)
100.                     file write tf _char(36) "`sg'" _char(36) "`st'"
101.                 }
102.             }
103.             file write tf " \\" _n
104.         }
105.     }
106. 
.     file write tf "\midrule" _n
107.     file write tf "Controls (age, female) & & \checkmark & & \checkmark \\" _n
108.     file write tf _char(36) "N" _char(36) " & `N_1' & `N_2' & `N_3' & `N_4' \\" _n
109.     file write tf "\bottomrule" _n
110.     file write tf "\multicolumn{5}{l}{\footnotesize \textit{Note:} " _char(36) "+" _cha
> r(36) " / " _char(36) "-" _char(36) " indicates direction; ns = not significant.}\\" _n
111.     file write tf "\multicolumn{5}{l}{\footnotesize *** " _char(36) "p" _char(36) "<0.0
> 1, ** " _char(36) "p" _char(36) "<0.05 (robust standard errors).}\\" _n
112.     file write tf "\multicolumn{5}{l}{\footnotesize Salary excluded from all models (se
> e Section~\ref{sec:notes}).}\\" _n
113.     file write tf "\end{tabular}" _n
114.     file write tf "\end{table}" _n
115.     file close tf
116. 
. }

